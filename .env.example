# Lucid environment configuration. Copy to .env and fill in the secrets.
# v2 stack: Postgres + Elasticsearch (with nori). Sprint 1A PR-1A-1.

# --- Required: LLM ---
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI is the beta embedding source (text-embedding-3-small, 1536 dim).
# Get a key at https://platform.openai.com/api-keys — keep this in .env only.
OPENAI_API_KEY=sk-...

# --- Required: Auth (Sprint 1B) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotate periodically; storing this in chat or git is a security incident.
SECRET_KEY=change-me-to-a-real-64-byte-urlsafe-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=43200  # 30 days

# --- Required: Postgres (relational store, auth, settings) ---
DATABASE_URL=postgresql://lucid:lucid@postgres:5432/lucid
POSTGRES_USER=lucid
POSTGRES_PASSWORD=lucid
POSTGRES_DB=lucid

# --- Required: Elasticsearch (graph adjacency + kNN + nori) ---
ELASTICSEARCH_URL=http://elasticsearch:9200

# --- Development flags ---
LUCID_MOCK_LLM=false           # true = use tests/mock_llm.py, no API calls
LUCID_ENV=development          # development | staging | production

# --- Claude model selection (beta default per PO 2026-05-21) ---
CLAUDE_MODEL=claude-sonnet-4-5

# --- Optional ---
YOUTUBE_TRANSCRIPT_LANG=ko,en  # Preferred transcript languages
MAX_FACTS_PER_CAPTURE=10       # Limit atomic facts per single capture
